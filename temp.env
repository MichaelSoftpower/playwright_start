#填測試用帳號密碼
FSUSERNAME=
FSPASSWORD=

# EDIT: 測試環境URL - 提供 STAGE 1~7 的可切換登入網址
# STAGE=1 npx playwright test --project=aaa
# 或
# STAGE=1 npx playwright test /tests/測試檔案位置
BASE_URL=https://stage.friendlysky.com/bos
STAGE_2=https://stage2.friendlysky.com/bos
STAGE_3=https://stage3.friendlysky.com/bos
STAGE_4=https://stage4.friendlysky.com/bos
STAGE_5=https://stage5.friendlysky.com/bos
STAGE_6=https://stage6.friendlysky.com/bos
STAGE_7=https://stage7.friendlysky.com/bos

# EDIT: 預設 STAGE 值，可透過指令切換，例如 PowerShell: $env:STAGE="2"
STAGE=1